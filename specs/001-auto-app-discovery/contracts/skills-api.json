{
  "openapi": "3.1.0",
  "info": {
    "title": "Radius Discovery Skills API",
    "version": "1.0.0",
    "description": "API contracts for Radius Automatic Application Discovery skills. These skills are exposed via CLI commands and MCP server."
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local MCP HTTP server"
    }
  ],
  "paths": {
    "/skills/discover_dependencies": {
      "post": {
        "operationId": "discoverDependencies",
        "summary": "Discover infrastructure dependencies from codebase",
        "description": "Analyzes a codebase to detect infrastructure dependencies (databases, caches, queues, storage) from library usage, imports, and configuration files.",
        "tags": ["discovery"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DiscoverDependenciesInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Dependencies discovered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DiscoverDependenciesOutput"
                }
              }
            }
          },
          "400": {
            "description": "Invalid input",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/skills/discover_services": {
      "post": {
        "operationId": "discoverServices",
        "summary": "Discover deployable services from codebase",
        "description": "Finds deployable services via entrypoints (main files, Dockerfiles, package.json scripts, framework conventions).",
        "tags": ["discovery"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DiscoverServicesInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Services discovered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DiscoverServicesOutput"
                }
              }
            }
          }
        }
      }
    },
    "/skills/discover_team_practices": {
      "post": {
        "operationId": "discoverTeamPractices",
        "summary": "Discover team infrastructure practices",
        "description": "Detects infrastructure conventions from existing IaC files (Terraform, Bicep, ARM), config files, and optionally external documentation.",
        "tags": ["discovery"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DiscoverTeamPracticesInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Team practices discovered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DiscoverTeamPracticesOutput"
                }
              }
            }
          }
        }
      }
    },
    "/skills/generate_resource_types": {
      "post": {
        "operationId": "generateResourceTypes",
        "summary": "Generate Resource Type definitions",
        "description": "Creates Resource Type schemas for detected dependencies, applying team practices for defaults and constraints.",
        "tags": ["generation"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerateResourceTypesInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Resource Types generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenerateResourceTypesOutput"
                }
              }
            }
          }
        }
      }
    },
    "/skills/discover_recipes": {
      "post": {
        "operationId": "discoverRecipes",
        "summary": "Discover matching recipes from configured sources",
        "description": "Searches configured recipe sources (AVM, internal registries) for IaC implementations matching the given resource types.",
        "tags": ["generation"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DiscoverRecipesInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Recipes discovered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DiscoverRecipesOutput"
                }
              }
            }
          }
        }
      }
    },
    "/skills/generate_app_definition": {
      "post": {
        "operationId": "generateAppDefinition",
        "summary": "Generate Radius application definition",
        "description": "Assembles discovered services, resource types, and selected recipes into a deployable app.bicep file.",
        "tags": ["generation"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerateAppDefinitionInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Application definition generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenerateAppDefinitionOutput"
                }
              }
            }
          }
        }
      }
    },
    "/skills/validate_app_definition": {
      "post": {
        "operationId": "validateAppDefinition",
        "summary": "Validate generated Bicep application definition",
        "description": "Validates the generated Bicep syntax, Resource Type references, and container-to-resource connections.",
        "tags": ["generation"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ValidateAppDefinitionInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Validation completed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidateAppDefinitionOutput"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DiscoverDependenciesInput": {
        "type": "object",
        "required": ["codebasePath"],
        "properties": {
          "codebasePath": {
            "type": "string",
            "description": "Absolute path to the codebase to analyze"
          },
          "excludePaths": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Paths to exclude from analysis (glob patterns)"
          },
          "confidenceThreshold": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "default": 0.5,
            "description": "Minimum confidence score to include dependencies"
          }
        }
      },
      "DiscoverDependenciesOutput": {
        "type": "object",
        "required": ["dependencies"],
        "properties": {
          "dependencies": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/DetectedDependency" }
          },
          "warnings": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Warning" }
          }
        }
      },
      "DetectedDependency": {
        "type": "object",
        "required": ["type", "technology", "confidence", "evidence"],
        "properties": {
          "type": {
            "type": "string",
            "description": "Normalized dependency type (e.g., 'postgresql', 'redis')"
          },
          "technology": {
            "type": "string",
            "description": "Specific technology (e.g., 'PostgreSQL', 'Azure Redis')"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Detection confidence (0.0 - 1.0)"
          },
          "evidence": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Evidence" }
          },
          "connectionInfo": {
            "$ref": "#/components/schemas/ConnectionInfo"
          }
        }
      },
      "Evidence": {
        "type": "object",
        "required": ["source", "type", "value"],
        "properties": {
          "source": {
            "type": "string",
            "description": "File path relative to codebase root"
          },
          "type": {
            "type": "string",
            "enum": ["package", "import", "config", "connection_string"]
          },
          "value": {
            "type": "string",
            "description": "The detected value"
          },
          "line": {
            "type": "integer",
            "description": "Line number in source file"
          }
        }
      },
      "ConnectionInfo": {
        "type": "object",
        "properties": {
          "envVar": { "type": "string" },
          "defaultPort": { "type": "integer" },
          "hostPattern": { "type": "string" }
        }
      },
      "DiscoverServicesInput": {
        "type": "object",
        "required": ["codebasePath"],
        "properties": {
          "codebasePath": {
            "type": "string",
            "description": "Absolute path to the codebase to analyze"
          },
          "excludePaths": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "DiscoverServicesOutput": {
        "type": "object",
        "required": ["services"],
        "properties": {
          "services": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/DetectedService" }
          }
        }
      },
      "DetectedService": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
            "description": "Service name (valid K8s name)"
          },
          "type": {
            "type": "string",
            "description": "Framework type (e.g., 'express', 'flask')"
          },
          "entrypoint": { "type": "string" },
          "port": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
          },
          "dockerfile": { "type": "string" },
          "buildContext": { "type": "string" }
        }
      },
      "DiscoverTeamPracticesInput": {
        "type": "object",
        "required": ["codebasePath"],
        "properties": {
          "codebasePath": {
            "type": "string",
            "description": "Absolute path to analyze for practices"
          },
          "configPath": {
            "type": "string",
            "description": "Path to .radius/team-practices.yaml"
          },
          "externalSources": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ExternalPracticeSource" },
            "description": "External documentation sources to analyze"
          }
        }
      },
      "ExternalPracticeSource": {
        "type": "object",
        "required": ["type", "location"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["wiki", "confluence", "notion", "markdown"]
          },
          "location": { "type": "string" },
          "authToken": { "type": "string" }
        }
      },
      "DiscoverTeamPracticesOutput": {
        "type": "object",
        "required": ["practices"],
        "properties": {
          "practices": { "$ref": "#/components/schemas/TeamPractices" }
        }
      },
      "TeamPractices": {
        "type": "object",
        "properties": {
          "naming": { "$ref": "#/components/schemas/NamingConvention" },
          "tags": { "$ref": "#/components/schemas/TagPolicy" },
          "sizing": {
            "type": "object",
            "additionalProperties": { "$ref": "#/components/schemas/SizingPolicy" }
          },
          "sources": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PracticeSource" }
          }
        }
      },
      "NamingConvention": {
        "type": "object",
        "required": ["pattern"],
        "properties": {
          "pattern": {
            "type": "string",
            "description": "Pattern with placeholders"
          },
          "maxLength": { "type": "integer" },
          "environmentAbbreviations": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      },
      "TagPolicy": {
        "type": "object",
        "required": ["required"],
        "properties": {
          "required": {
            "type": "array",
            "items": { "type": "string" }
          },
          "recommended": {
            "type": "array",
            "items": { "type": "string" }
          },
          "defaults": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      },
      "SizingPolicy": {
        "type": "object",
        "required": ["defaultTier", "haEnabled"],
        "properties": {
          "defaultTier": { "type": "string" },
          "haEnabled": { "type": "boolean" },
          "backupEnabled": { "type": "boolean" },
          "geoRedundant": { "type": "boolean" }
        }
      },
      "PracticeSource": {
        "type": "object",
        "required": ["type", "location", "detectedAt"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["iac", "config", "wiki", "manual"]
          },
          "location": { "type": "string" },
          "detectedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "GenerateResourceTypesInput": {
        "type": "object",
        "required": ["dependencies"],
        "properties": {
          "dependencies": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/DetectedDependency" }
          },
          "practices": { "$ref": "#/components/schemas/TeamPractices" }
        }
      },
      "GenerateResourceTypesOutput": {
        "type": "object",
        "required": ["resourceTypes"],
        "properties": {
          "resourceTypes": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ResourceType" }
          }
        }
      },
      "ResourceType": {
        "type": "object",
        "required": ["name", "type", "apiVersion", "schema", "outputs", "maturity"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "apiVersion": { "type": "string" },
          "schema": { "$ref": "#/components/schemas/ResourceSchema" },
          "outputs": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/OutputDefinition" }
          },
          "maturity": {
            "type": "string",
            "enum": ["alpha", "beta", "stable"]
          }
        }
      },
      "ResourceSchema": {
        "type": "object",
        "required": ["properties"],
        "properties": {
          "properties": {
            "type": "object",
            "additionalProperties": { "$ref": "#/components/schemas/PropertyDef" }
          },
          "required": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "PropertyDef": {
        "type": "object",
        "required": ["type", "description"],
        "properties": {
          "type": { "type": "string" },
          "description": { "type": "string" },
          "default": {},
          "enum": { "type": "array" },
          "sensitive": { "type": "boolean" }
        }
      },
      "OutputDefinition": {
        "type": "object",
        "required": ["name", "type", "description"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "description": { "type": "string" },
          "sensitive": { "type": "boolean" }
        }
      },
      "DiscoverRecipesInput": {
        "type": "object",
        "required": ["resourceTypes"],
        "properties": {
          "resourceTypes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "profile": {
            "type": "string",
            "description": "Environment profile (e.g., 'dev', 'production')"
          },
          "sources": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/RecipeSourceConfig" }
          }
        }
      },
      "RecipeSourceConfig": {
        "type": "object",
        "required": ["type", "location"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["avm", "oci", "terraform-registry", "filesystem"]
          },
          "location": { "type": "string" },
          "priority": { "type": "integer" }
        }
      },
      "DiscoverRecipesOutput": {
        "type": "object",
        "required": ["recipes"],
        "properties": {
          "recipes": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": { "$ref": "#/components/schemas/Recipe" }
            },
            "description": "Map of resource type to available recipes"
          }
        }
      },
      "Recipe": {
        "type": "object",
        "required": ["name", "iacType", "templatePath", "resourceType"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "iacType": {
            "type": "string",
            "enum": ["bicep", "terraform"]
          },
          "templatePath": { "type": "string" },
          "parameters": {
            "type": "object",
            "additionalProperties": { "$ref": "#/components/schemas/PropertyDef" }
          },
          "source": { "$ref": "#/components/schemas/RecipeSourceInfo" },
          "environments": {
            "type": "array",
            "items": { "type": "string" }
          },
          "resourceType": { "type": "string" },
          "verified": { "type": "boolean" }
        }
      },
      "RecipeSourceInfo": {
        "type": "object",
        "required": ["type", "location"],
        "properties": {
          "type": { "type": "string" },
          "location": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "GenerateAppDefinitionInput": {
        "type": "object",
        "required": ["appName", "services", "recipeSelections"],
        "properties": {
          "appName": { "type": "string" },
          "services": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/DetectedService" }
          },
          "recipeSelections": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/RecipeSelection" }
          },
          "practices": { "$ref": "#/components/schemas/TeamPractices" },
          "outputPath": {
            "type": "string",
            "default": "./radius/app.bicep"
          }
        }
      },
      "RecipeSelection": {
        "type": "object",
        "required": ["dependency", "recipe"],
        "properties": {
          "dependency": { "type": "string" },
          "recipe": { "$ref": "#/components/schemas/Recipe" },
          "parameters": {
            "type": "object",
            "additionalProperties": {}
          },
          "environment": { "type": "string" }
        }
      },
      "GenerateAppDefinitionOutput": {
        "type": "object",
        "required": ["path", "content"],
        "properties": {
          "path": {
            "type": "string",
            "description": "Path to generated file"
          },
          "content": {
            "type": "string",
            "description": "Generated Bicep content"
          },
          "structure": { "$ref": "#/components/schemas/AppStructure" }
        }
      },
      "AppStructure": {
        "type": "object",
        "properties": {
          "containers": {
            "type": "array",
            "items": { "type": "string" }
          },
          "resources": {
            "type": "array",
            "items": { "type": "string" }
          },
          "connections": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ConnectionSummary" }
          }
        }
      },
      "ConnectionSummary": {
        "type": "object",
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" }
        }
      },
      "ValidateAppDefinitionInput": {
        "type": "object",
        "required": ["bicepContent"],
        "properties": {
          "bicepContent": {
            "type": "string",
            "description": "Bicep content to validate"
          },
          "filePath": {
            "type": "string",
            "description": "Path for error reporting"
          }
        }
      },
      "ValidateAppDefinitionOutput": {
        "type": "object",
        "required": ["valid"],
        "properties": {
          "valid": { "type": "boolean" },
          "errors": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ValidationError" }
          },
          "warnings": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ValidationError" }
          }
        }
      },
      "ValidationError": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "line": { "type": "integer" },
          "column": { "type": "integer" }
        }
      },
      "Warning": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "file": { "type": "string" }
        }
      },
      "Error": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "details": {
            "type": "object",
            "additionalProperties": {}
          }
        }
      }
    }
  }
}
